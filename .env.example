# Canonical public URL (no trailing slash). Used for sitemap.xml, robots.txt, and optional static OG URL injection in index.html.
# Set this in Netlify: Site settings → Environment variables → VITE_SITE_URL
# VITE_SITE_URL=https://your-site.netlify.app

# Optional: Twitter @handle for twitter:site (without @)
# VITE_TWITTER_SITE=@yourproject
